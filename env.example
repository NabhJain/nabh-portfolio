# Environment configuration for the AI Assistant.
# Copy to `.env.local` and adjust per environment.

# Provider: "mock" | "huggingface" | "fastapi" | "local"
VITE_CHAT_PROVIDER=mock

# Provider URLs — used only if the corresponding provider is selected.
VITE_HUGGINGFACE_URL=
VITE_FASTAPI_URL=
VITE_LOCAL_API_URL=http://localhost:8000/chat
